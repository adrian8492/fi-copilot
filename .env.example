# ─── F&I Co-Pilot — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in the values.
# All secrets should be managed through the Manus platform secrets manager.

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/database

# ─── Encryption (REQUIRED) ────────────────────────────────────────────────────
# 64-char hex string for AES-256-GCM field-level encryption (CFPB compliance).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Auth / OAuth (Manus Platform) ────────────────────────────────────────────
JWT_SECRET=
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# ─── Manus Built-in APIs ──────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ─── AI / Transcription (Optional) ────────────────────────────────────────────
# Real-time server-side transcription. Falls back to browser SpeechRecognition.
# Get a key at https://console.deepgram.com
DEEPGRAM_API_KEY=

# ─── Email (Optional) ─────────────────────────────────────────────────────────
# Session summary + compliance alert emails. Silent no-op if not set.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=F&I Co-Pilot <noreply@ficopilotsystem.com>

# ─── Frontend / UI (Optional) ─────────────────────────────────────────────────
VITE_APP_TITLE=F&I Co-Pilot
VITE_APP_LOGO=
VITE_DELPHI_EMBED_URL=

# ─── Analytics (Optional) ─────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
